{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "schema_version": {
          "minLength": 1,
          "title": "Schema Version",
          "type": "string"
        },
        "media_type": {
          "default": "application/json",
          "title": "Media Type",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "2.0",
      "default": "2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "artifact_type": {
      "const": "run_manifest",
      "default": "run_manifest",
      "title": "Artifact Type",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "run_kind": {
      "enum": [
        "pilot",
        "formal",
        "smoke",
        "development"
      ],
      "title": "Run Kind",
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    },
    "git_sha": {
      "default": "",
      "title": "Git Sha",
      "type": "string"
    },
    "config_sha256": {
      "default": "",
      "title": "Config Sha256",
      "type": "string"
    },
    "dataset_manifest_sha256": {
      "default": "",
      "title": "Dataset Manifest Sha256",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "metrics": {
      "additionalProperties": true,
      "title": "Metrics",
      "type": "object"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "run_id",
    "run_kind",
    "status"
  ],
  "title": "RunManifest",
  "type": "object"
}
