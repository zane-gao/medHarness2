{
  "$defs": {
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "minLength": 1,
          "title": "Finding Id",
          "type": "string"
        },
        "observation_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Code"
        },
        "observation_text": {
          "minLength": 1,
          "title": "Observation Text",
          "type": "string"
        },
        "anatomy_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Anatomy Code"
        },
        "location_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location Text"
        },
        "laterality": {
          "default": "unknown",
          "enum": [
            "left",
            "right",
            "bilateral",
            "midline",
            "unknown"
          ],
          "title": "Laterality",
          "type": "string"
        },
        "certainty": {
          "default": "present",
          "enum": [
            "present",
            "absent",
            "uncertain"
          ],
          "title": "Certainty",
          "type": "string"
        },
        "severity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity"
        },
        "measurements": {
          "items": {
            "$ref": "#/$defs/Measurement"
          },
          "title": "Measurements",
          "type": "array"
        },
        "source_span": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_text": {
          "default": "",
          "title": "Source Text",
          "type": "string"
        },
        "extractor": {
          "$ref": "#/$defs/ModelProvenance"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        }
      },
      "required": [
        "finding_id",
        "observation_text",
        "extractor"
      ],
      "title": "Finding",
      "type": "object"
    },
    "Measurement": {
      "additionalProperties": false,
      "properties": {
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "enum": [
            "mm",
            "cm"
          ],
          "title": "Unit",
          "type": "string"
        },
        "normalized_mm": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized Mm"
        }
      },
      "required": [
        "value",
        "unit"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "ModelProvenance": {
      "additionalProperties": false,
      "properties": {
        "implementation_type": {
          "minLength": 1,
          "title": "Implementation Type",
          "type": "string"
        },
        "provider": {
          "default": "",
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "default": "",
          "title": "Model",
          "type": "string"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        },
        "role": {
          "default": "",
          "title": "Role",
          "type": "string"
        },
        "prompt_version": {
          "default": "",
          "title": "Prompt Version",
          "type": "string"
        },
        "fallback_used": {
          "default": false,
          "title": "Fallback Used",
          "type": "boolean"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "implementation_type"
      ],
      "title": "ModelProvenance",
      "type": "object"
    },
    "TextSpan": {
      "additionalProperties": false,
      "properties": {
        "start": {
          "minimum": 0,
          "title": "Start",
          "type": "integer"
        },
        "end": {
          "minimum": 0,
          "title": "End",
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "TextSpan",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "2.0",
      "default": "2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "artifact_type": {
      "const": "finding_graph",
      "default": "finding_graph",
      "title": "Artifact Type",
      "type": "string"
    },
    "modality": {
      "minLength": 1,
      "title": "Modality",
      "type": "string"
    },
    "backend": {
      "minLength": 1,
      "title": "Backend",
      "type": "string"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "relations": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Relations",
      "type": "array"
    },
    "missing": {
      "items": {
        "type": "string"
      },
      "title": "Missing",
      "type": "array"
    },
    "coverage": {
      "default": 0.0,
      "maximum": 1,
      "minimum": 0,
      "title": "Coverage",
      "type": "number"
    },
    "nodes": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Nodes",
      "type": "array"
    },
    "template_coverage": {
      "additionalProperties": true,
      "title": "Template Coverage",
      "type": "object"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "modality",
    "backend"
  ],
  "title": "FindingGraph",
  "type": "object"
}
