    "CandidateReportStructure": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "2.0",
          "default": "2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "artifact_type": {
          "const": "candidate_report_structure",
          "default": "candidate_report_structure",
          "title": "Artifact Type",
          "type": "string"
        },
        "structure_status": {
          "enum": [
            "succeeded",
            "empty_report",
            "failed"
          ],
          "title": "Structure Status",
          "type": "string"
        },
        "structure_version": {
          "const": "candidate-structure-v2",
          "default": "candidate-structure-v2",
          "title": "Structure Version",
          "type": "string"
        },
        "modality": {
          "minLength": 1,
          "title": "Modality",
          "type": "string"
        },
        "body_part": {
          "minLength": 1,
          "title": "Body Part",
          "type": "string"
        },
        "sections": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Sections",
          "type": "object"
        },
        "spans": {
          "items": {
            "$ref": "#/$defs/CandidateStructureSpan"
          },
          "title": "Spans",
          "type": "array"
        },
        "entities": {
          "items": {
            "$ref": "#/$defs/CandidateStructureEntity"
          },
          "title": "Entities",
          "type": "array"
        },
        "finding_graph": {
          "$ref": "#/$defs/FindingGraph"
        },
        "template": {
          "$ref": "#/$defs/StructureTemplateAttachment"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "structure_status",
        "modality",
        "body_part",
        "finding_graph",
        "template"
      ],
      "title": "CandidateReportStructure",
      "type": "object"
    },
