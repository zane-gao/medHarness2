    "modality": {
      "minLength": 1,
      "title": "Modality",
      "type": "string"
    },
    "evidence_tier": {
      "enum": [
        "formal_fresh",
        "exploratory_fresh",
        "artifact",
        "debug_fallback",
        "mock"
      ],
