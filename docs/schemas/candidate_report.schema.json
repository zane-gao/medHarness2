        "template_id": {
          "minLength": 1,
          "title": "Template Id",
          "type": "string"
        },
        "template_version": {
          "minLength": 1,
          "title": "Template Version",
          "type": "string"
        },
        "template_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Template Sha256",
          "type": "string"
        },
        "registry_version": {
          "minLength": 1,
          "title": "Registry Version",
          "type": "string"
        },
        "registry_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Registry Sha256",
          "type": "string"
